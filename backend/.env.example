# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# LLM Settings (OpenAI)
LLM_PROVIDER=openai
LLM_MODEL=deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
LLM_API_KEY= # enter ur api_key
LLM_BASE_URL=https://api.siliconflow.cn/v1 # replace ur base_url
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Embedding Settings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY= # enter ur api_key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1 # replace ur base_url
EMBEDDING_DIMENSION=1536

# Vector Store Settings
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_db

# RAG Settings
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7
RAG_MAX_CONTEXT_LENGTH=4000

# CORS Settings
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
